[0.48 0 0 0.47974 0 0] CT
[1 0 0 1 0 0] CT
N
0 0 M
1250 0 L
1250 938 L
0 938 L
0 0 L
cp
clip
GS
0 0 translate
1250 938 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 938
  /ImageMatrix [1250 0 0 938 0 0]
  /Width 1250
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
